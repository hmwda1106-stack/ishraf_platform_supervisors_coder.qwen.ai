  "item": [
    {
      "name": "Auth",
      "description": "Authentication, session lifecycle, password recovery, and current-user endpoints.",
      "item": [
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Purpose: Change the current authenticated user password.\n\nRoles: admin, parent, teacher, supervisor, driver\n\nAuth: Bearer access token required\n\nBody schema: ChangePasswordRequest",
            "url": {
              "raw": "{{baseUrl}}/auth/change-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "change-password"
              ],
              "query": []
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"{{loginPassword}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Purpose: Request a password reset token for an active account. Staging usually does not expose resetToken in the response.\n\nRoles: public\n\nAuth: No bearer token required\n\nBody schema: ForgotPasswordRequest",
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "forgot-password"
              ],
              "query": []
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{loginIdentifier}}\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Purpose: Authenticate with email or phone and issue access and refresh tokens.\n\nRoles: public\n\nAuth: No bearer token required\n\nBody schema: LoginRequest",
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ],
              "query": []
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{loginIdentifier}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (pm.response.code === 200 && json?.success && json?.data) {",
                  "  if (json.data.accessToken) pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  if (json.data.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "  if (json.data.user?.id) pm.collectionVariables.set('userId', json.data.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Purpose: Revoke the provided refresh token.\n\nRoles: public\n\nAuth: No bearer token required\n\nBody schema: LogoutRequest",
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ],
              "query": []
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "description": "Purpose: Return the authenticated active user profile used for frontend bootstrap.\n\nRoles: admin, parent, teacher, supervisor, driver\n\nAuth: Bearer access token required",
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ],
              "query": []
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Purpose: Exchange a valid refresh token for a fresh access/refresh pair.\n\nRoles: public\n\nAuth: No bearer token required\n\nBody schema: RefreshTokenRequest",
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ],
              "query": []
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (pm.response.code === 200 && json?.success && json?.data) {",
                  "  if (json.data.accessToken) pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  if (json.data.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Purpose: Reset the password using a valid reset token. Successful reset revokes existing refresh tokens.\n\nRoles: public\n\nAuth: No bearer token required\n\nBody schema: ResetPasswordRequest",
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "reset-password"
              ],
              "query": []
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
            }
          }
        }
      ]
    }
  ]
